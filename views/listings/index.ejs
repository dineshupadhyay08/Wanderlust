<% layout('/layouts/boilerplate') -%>

<section class="page-shell fade-in-up">
  <div class="hero-panel glass-panel">
    <span class="auth-eyebrow">Curated escapes</span>
    <h1 class="page-title">Luxury stays designed for your next remarkable trip.</h1>
    <p class="page-subtitle mb-0">Explore handpicked villas, design-led rooms, iconic city stays, mountain retreats, and rare destinations with a polished premium browsing experience.</p>
    <div class="hero-stats">
      <div class="hero-stat">
        <strong><%= allListings.length %>+</strong>
        <span>Curated listings</span>
      </div>
      <div class="hero-stat">
        <strong>7 categories</strong>
        <span>From trending to arctic escapes</span>
      </div>
      <div class="hero-stat">
        <strong>Instant feel</strong>
        <span>Cleaner cards and visual hierarchy</span>
      </div>
    </div>
  </div>

  <div id="filters" class="filter-bar fade-in-up">
    <div class="filter-scroll">
      <div class="filter">
        <a class="filter-link" href="/listings/trending">
          <div><i class="fa-solid fa-fire"></i></div>
          <p>Trending</p>
        </a>
      </div>
      <div class="filter">
        <a class="filter-link" href="/listings/room">
          <div><i class="fa-solid fa-bed"></i></div>
          <p>Rooms</p>
        </a>
      </div>
      <div class="filter">
        <a class="filter-link" href="/listings/boats">
          <div><i class="fa-solid fa-ship"></i></div>
          <p>Boats</p>
        </a>
      </div>
      <div class="filter">
        <a class="filter-link" href="/listings/Iconic-cities">
          <div><i class="fa-solid fa-mountain-city"></i></div>
          <p>Iconic Cities</p>
        </a>
      </div>
      <div class="filter">
        <a class="filter-link" href="/listings/mountain">
          <div><i class="fa-solid fa-mountain"></i></div>
          <p>Mountains</p>
        </a>
      </div>
      <div class="filter">
        <a class="filter-link" href="/listings/Arctic">
          <div><i class="fa-regular fa-snowflake"></i></div>
          <p>Arctic</p>
        </a>
      </div>
      <div class="filter">
        <a class="filter-link" href="/listings/pools">
          <div><i class="fa-solid fa-person-swimming"></i></div>
          <p>Pools</p>
        </a>
      </div>
    </div>

    <div class="tax-toggle">
      <div class="form-check form-switch m-0">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault" />
        <label class="form-check-label" for="switchCheckDefault">Show total after taxes</label>
      </div>
    </div>
  </div>

  <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 listing-grid" id="listingsContainer">
    <% for(let listing of allListings) { %>
      <div class="col fade-in-up">
        <a href="/listings/<%=listing._id %>" class="listing-link">
          <div class="card listing-card">
            <div class="card-img-wrap">
              <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>" style="height: 20rem" />
            </div>
            <div class="card-body">
              <h5 class="card-title mb-2"><%= listing.title %></h5>
              <div class="listing-meta">
                <span class="listing-price">&#8377; <%= listing.price.toLocaleString("en-IN") %> / night</span>
                <span><%= listing.location %>, <%= listing.country %></span>
                <i class="taxInfo">+18% GST included</i>
              </div>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>
</section>
