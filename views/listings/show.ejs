<% layout('/layouts/boilerplate') -%>
<script>
  const mapToken = "<%= process.env.MAP_TOKEN %>";
  const coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;
</script>

<section class="page-shell fade-in-up">
  <div class="mb-4">
    <span class="auth-eyebrow">Stay details</span>
    <h1 class="page-title mb-2"><%= listing.title %></h1>
    <div class="detail-meta">
      <span class="owner-pill"><i class="fa-regular fa-user"></i> Hosted by <%=listing.owner.username %></span>
      <span class="location-pill"><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></span>
    </div>
  </div>

  <div class="detail-layout">
    <div class="detail-main">
      <div class="card detail-card fade-in-up">
        <div class="card-img-wrap">
          <img src="<%= listing.image.url %>" class="card-img-top show-image" alt="<%= listing.title %>" />
        </div>
        <div class="card-body">
          <p class="detail-price mb-3">&#8377; <%= listing.price.toLocaleString("en-IN") %> / night</p>
          <p class="card-text muted-copy mb-0"><%= listing.description %></p>
        </div>
      </div>

      <% if(currUser && listing.owner._id.equals(currUser._id)) { %>
        <div class="detail-actions">
          <a href="/listings/<%=listing._id %>/edit" class="btn btn-dark">Edit Listing</a>
          <form method="POST" action="/listings/<%=listing._id %>?_method=DELETE">
            <button class="btn btn-outline-dark">Delete Listing</button>
          </form>
        </div>
      <% } %>
    </div>

    <div class="detail-sidebar">
      <div class="form-shell fade-in-up">
        <h3 class="section-heading mb-3">Where you'll be</h3>
        <div id="map"></div>
      </div>
    </div>
  </div>

  <div class="row mt-4">
    <div class="col-12 col-xl-8">
      <% if(currUser)  {%>
      <div class="form-shell mb-4 fade-in-up">
        <h4 class="section-heading mb-3">Leave a Review</h4>
        <form action="/listings/<%=listing.id %>/reviews" method="POST" novalidate class="needs-validation">
          <div class="mb-3">
            <label for="rating" class="form-label">Rating</label>
            <fieldset class="starability-slot">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>
          <div class="mb-3">
            <label for="comment" class="form-label">Comment</label>
            <textarea name="review[comment]" id="comment" cols="20" rows="5" class="form-control" required></textarea>
            <div class="invalid-feedback">Please add some comment for review</div>
          </div>
          <button class="btn btn-outline-dark">Submit</button>
        </form>
      </div>
      <% } %>

      <% if(listing.reviews.length > 0)  { %>
      <div class="mt-4">
        <h4 class="section-heading mb-3">Guest Reviews</h4>
        <div class="row g-3">
          <%for(review of listing.reviews) { %>
          <div class="col-md-6">
            <div class="card review-card">
              <div class="card-body">
                <h5 class="card-title">
                  <% if (review.author) { %>
                    @<%= review.author.username %>
                  <% } else { %>
                    Unknown User
                  <% } %>
                </h5>
                <p class="starability-result card-text" data-rating=<%=review.rating %>></p>
                <p class="card-text muted-copy"><%=review.comment %></p>
                <form class="mb-0" method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id %>?_method=DELETE">
                  <button class="btn btn-sm btn-outline-dark">Delete</button>
                </form>
              </div>
            </div>
          </div>
          <% } %>
        </div>
      </div>
      <% } else { %>
      <div class="empty-state mt-4">No reviews yet. Be the first to share your experience.</div>
      <% } %>
    </div>
  </div>
</section>

<script src="/js/map.js"></script>
