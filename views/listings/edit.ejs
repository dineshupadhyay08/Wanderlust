<% layout('/layouts/boilerplate') -%>
<section class="page-shell fade-in-up">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-9 col-xl-8">
      <div class="form-shell">
        <span class="auth-eyebrow">Refine your stay</span>
        <h1 class="page-title">Edit your listing</h1>
        <p class="page-subtitle">Update presentation details without changing any of the underlying listing behavior.</p>
        <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation mt-4" enctype="multipart/form-data">
          <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input type="text" name="listing[title]" value="<%= listing.title %>" class="form-control" />
          </div>
          <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listing[description]" class="form-control" rows="5"><%=listing.description%></textarea>
          </div>
          <div class="mb-3">
            <label for="image" class="form-label">Upload New Image</label>
            <input type="file" class="form-control" name="listing[image]" />
          </div>
          <div class="row">
            <div class="mb-3 col-md-4">
              <label for="price" class="form-label">Price</label>
              <input type="number" name="listing[price]" class="form-control" value="<%=listing.price%>" />
            </div>
            <div class="mb-3 col-md-8">
              <label for="country" class="form-label">Country</label>
              <input type="text" name="listing[country]" class="form-control" value="<%=listing.country%>" />
            </div>
          </div>
          <div class="mb-4">
            <label for="location" class="form-label">Location</label>
            <input type="text" name="listing[location]" class="form-control" value="<%=listing.location %>" />
          </div>
          <button class="btn btn-dark edit-btn">Save Changes</button>
        </form>
      </div>
    </div>
  </div>
</section>
